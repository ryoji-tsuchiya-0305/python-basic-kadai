      "source": [
        "def Including_tax(value: int, tax: float) -> float:\n",
        "\n",
        "  tax_rate = tax / 100\n",
        "  total_price = value * (1 + tax_rate)\n",
        "  return total_price\n",
        "\n",
        "value1 = 110\n",
        "tax1 = 10\n",
        "\n",
        "result = Including_tax(value1,tax1)\n",
        "\n",
        "print(f\"税込価格{result}円\")\n"
      ],
